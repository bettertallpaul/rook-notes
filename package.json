{
  "name": "rook-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "pnpm --filter @rook/shared build && pnpm --filter @rook/frontend build && pnpm --filter @rook/api build && pnpm --filter @rook/mcp build",
    "design:lint": "npx @google/design.md lint DESIGN.md",
    "design:diff": "npx @google/design.md diff DESIGN.md",
    "design:export": "npx @google/design.md export",
    "design:spec": "npx @google/design.md spec"
  },
  "devDependencies": {
    "@google/design.md": "latest",
    "typescript": "^5.5.3"
  }
}
